a=input("enter password")
up=0
sm=0
sp=0
di=0
if len(a)>7:
   for i in a:
       if i.isupper():
           up=up+1
       elif i.islower():
            sm=sm+1
       elif i.isdigit():
            di=di+1
       else:
            sp=sp+1
   if up>0 and sm>0 and di>0 and sp>0:
        print("strong password")
   else:
        print("weak password")
else:
     print("weak password due to less char")

